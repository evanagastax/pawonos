{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "incremental": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@pawonos/database": ["./packages/database/src"],
      "@pawonos/types": ["./packages/types/src"],
      "@pawonos/validation": ["./packages/validation/src"],
      "@pawonos/ui": ["./packages/ui/src"],
      "@pawonos/utils": ["./packages/utils/src"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", ".turbo"]
}